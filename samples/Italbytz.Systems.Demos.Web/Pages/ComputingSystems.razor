@page "/computing-systems"

<PageTitle>Computing systems demo</PageTitle>

<section class="hero-panel page-hero computing-hero">
    <div>
        <p class="eyebrow">Italbytz.ComputingSystems</p>
        <h1>Work through binary arithmetic with the concrete package.</h1>
        <p class="hero-copy">
            These examples use the repository's actual computing-systems solvers for addition, binary conversion, and two's-complement tasks.
        </p>
    </div>
    <div class="hero-note">
        <strong>Included solvers</strong>
        <span>BinaryAdditionSolver</span>
        <span>DecimalToBinarySolver</span>
        <span>BinaryToDecimalSolver</span>
        <span>TwosComplementSolver</span>
        <span>NormalFormSolver</span>
        <span>QuineMcCluskeySolver</span>
        <span>KarnaughMapSolver</span>
    </div>
</section>

<section class="section-stack">
    <div class="card-grid card-grid-two">
        <article class="demo-card">
            <div class="card-heading">
                <p class="feature-kicker">Binary addition</p>
                <h2>Add two 8-bit values</h2>
            </div>

            <div class="input-grid two-up">
                <label>
                    <span>Summand A</span>
                    <input type="number" min="0" max="255" @bind="AdditionLeft" />
                </label>
                <label>
                    <span>Summand B</span>
                    <input type="number" min="0" max="255" @bind="AdditionRight" />
                </label>
            </div>

            @{ var addition = AdditionSolution; }
            <div class="result-stack">
                <div class="metric-row">
                    <span>Binary A</span>
                    <strong>@ToBinary(AdditionLeftByte)</strong>
                </div>
                <div class="metric-row">
                    <span>Binary B</span>
                    <strong>@ToBinary(AdditionRightByte)</strong>
                </div>
                <div class="metric-row accent-row">
                    <span>Sum</span>
                    <strong>@addition.Sum (@ToBinary((int)addition.Sum, 16))</strong>
                </div>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>Trace step</th>
                            <th>Trace detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < addition.Steps.Count; index++)
                        {
                            <tr>
                                <td>@(index + 1)</td>
                                <td>@addition.Steps[index]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>

        <article class="demo-card">
            <div class="card-heading">
                <p class="feature-kicker">Conversion</p>
                <h2>Switch between decimal and binary</h2>
            </div>

            <div class="input-grid two-up">
                <label>
                    <span>Decimal input</span>
                    <input type="number" min="0" max="255" @bind="DecimalInput" />
                </label>
                <label>
                    <span>Binary input</span>
                    <input type="text" inputmode="numeric" maxlength="8" @bind="BinaryInput" />
                </label>
            </div>

            @{ var decimalToBinary = DecimalToBinarySolution; }
            @{ var binaryToDecimal = BinaryToDecimalSolution; }
            <div class="result-stack">
                <div class="metric-row">
                    <span>Decimal to binary</span>
                    <strong>@ToBinary(decimalToBinary.Binary)</strong>
                </div>
                <div class="metric-row">
                    <span>Binary to decimal</span>
                    <strong>@binaryToDecimal.Decimal</strong>
                </div>
                <p class="helper-copy">Binary input accepts up to eight bits and ignores any non-binary characters.</p>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>Trace step</th>
                            <th>Trace detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < decimalToBinary.Steps.Count; index++)
                        {
                            <tr>
                                <td>@(index + 1)</td>
                                <td>@decimalToBinary.Steps[index]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>Trace step</th>
                            <th>Trace detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < binaryToDecimal.Steps.Count; index++)
                        {
                            <tr>
                                <td>@(index + 1)</td>
                                <td>@binaryToDecimal.Steps[index]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>
    </div>

    <article class="demo-card wide-card">
        <div class="card-heading">
            <p class="feature-kicker">Two's complement</p>
            <h2>Inspect the signed representation</h2>
        </div>

        <div class="input-grid single-up">
            <label>
                <span>Positive input</span>
                <input type="number" min="0" max="127" @bind="TwosComplementInput" />
            </label>
        </div>

        @{ var twosComplement = TwosComplementSolution; }
        <div class="card-grid card-grid-three compact-grid">
            <div class="metric-card">
                <span>Input</span>
                <strong>@TwosComplementInputByte</strong>
                <small>@ToBinary(TwosComplementInputByte)</small>
            </div>
            <div class="metric-card">
                <span>Signed result</span>
                <strong>@twosComplement.ComplementBinary</strong>
                <small>solver output</small>
            </div>
            <div class="metric-card">
                <span>Stored bits</span>
                <strong>@ToBinary(unchecked((byte)twosComplement.ComplementBinary))</strong>
                <small>8-bit view</small>
            </div>
        </div>

        <div class="table-shell">
            <table class="trace-table">
                <thead>
                    <tr>
                        <th>Trace step</th>
                        <th>Trace detail</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < twosComplement.Steps.Count; index++)
                    {
                        <tr>
                            <td>@(index + 1)</td>
                            <td>@twosComplement.Steps[index]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </article>

    <article class="demo-card wide-card">
        <div class="card-heading">
            <p class="feature-kicker">Boolean normal forms</p>
            <h2>Generate canonical DNF and CNF from a truth table</h2>
        </div>

        <div class="input-grid two-up">
            <label>
                <span>Variable count</span>
                <input type="number" min="1" max="4" @bind="NormalFormVariableCount" />
            </label>
            <label>
                <span>Truth values</span>
                <input type="text" @bind="NormalFormTruthValuesInput" />
            </label>
        </div>

        <p class="helper-copy">Provide one comma-separated 0/1 value per truth-table row in lexicographic order, for example <strong>0,1,1,0</strong> for a two-variable XOR.</p>

        @if (TryGetNormalFormSolution(out var normalFormSolution, out var normalFormError))
        {
            <div class="card-grid card-grid-two compact-grid">
                <div class="metric-card">
                    <span>DNF</span>
                    <strong>@normalFormSolution!.Dnf</strong>
                </div>
                <div class="metric-card">
                    <span>CNF</span>
                    <strong>@normalFormSolution.Cnf</strong>
                </div>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>Trace step</th>
                            <th>Trace detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < normalFormSolution.Steps.Count; index++)
                        {
                            <tr>
                                <td>@(index + 1)</td>
                                <td>@normalFormSolution.Steps[index]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="validation-copy">@normalFormError</p>
        }
    </article>

    <article class="demo-card wide-card">
        <div class="card-heading">
            <p class="feature-kicker">Boolean minimization</p>
            <h2>Inspect Quine-McCluskey output and Karnaugh groups</h2>
        </div>

        <div class="input-grid two-up">
            <label>
                <span>Variable count</span>
                <input type="number" min="1" max="4" @bind="QmcVariableCount" />
            </label>
            <label>
                <span>Truth values</span>
                <input type="text" @bind="QmcTruthValuesInput" />
            </label>
        </div>

        <p class="helper-copy">Use comma-separated values with <strong>0</strong>, <strong>1</strong>, and optional <strong>2</strong> for don't cares.</p>

        @if (TryGetQuineMcCluskeySolution(out var qmcSolution, out var qmcError) && TryGetKarnaughMapSolution(out var karnaughSolution, out _))
        {
            <div class="card-grid card-grid-three compact-grid">
                <div class="metric-card">
                    <span>Minimal DNF</span>
                    <strong>@qmcSolution!.MinimalDnf</strong>
                </div>
                <div class="metric-card">
                    <span>Prime implicants</span>
                    <strong>@string.Join(", ", qmcSolution.PrimeImplicants)</strong>
                </div>
                <div class="metric-card">
                    <span>Essential prime implicants</span>
                    <strong>@string.Join(", ", qmcSolution.EssentialPrimeImplicants)</strong>
                </div>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>KV cell</th>
                            <th>Gray code</th>
                            <th>Minterm</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cell in karnaughSolution!.Cells.OrderBy(cell => cell.RowIndex).ThenBy(cell => cell.ColumnIndex))
                        {
                            <tr>
                                <td>r@cell.RowIndex c@cell.ColumnIndex</td>
                                <td>@cell.RowCode | @cell.ColumnCode</td>
                                <td>@cell.MintermIndex</td>
                                <td>@cell.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>Group</th>
                            <th>Essential</th>
                            <th>Covered minterms</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in karnaughSolution.Groups)
                        {
                            <tr>
                                <td>@group.Term</td>
                                <td>@(group.IsEssential ? "yes" : "no")</td>
                                <td>@string.Join(", ", group.CoveredMintermIndices)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-shell">
                <table class="trace-table">
                    <thead>
                        <tr>
                            <th>Trace step</th>
                            <th>Trace detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var index = 0; index < qmcSolution.Steps.Count; index++)
                        {
                            <tr>
                                <td>@(index + 1)</td>
                                <td>@qmcSolution.Steps[index]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="validation-copy">@qmcError</p>
        }
    </article>
</section>

@code {
    private readonly BinaryAdditionSolver additionSolver = new();
    private readonly DecimalToBinarySolver decimalToBinarySolver = new();
    private readonly BinaryToDecimalSolver binaryToDecimalSolver = new();
    private readonly TwosComplementSolver twosComplementSolver = new();
    private readonly NormalFormSolver normalFormSolver = new();
    private readonly QuineMcCluskeySolver quineMcCluskeySolver = new();
    private readonly KarnaughMapSolver karnaughMapSolver = new();

    private int AdditionLeft { get; set; } = 13;
    private int AdditionRight { get; set; } = 29;
    private int DecimalInput { get; set; } = 42;
    private string BinaryInput { get; set; } = "101101";
    private int TwosComplementInput { get; set; } = 37;
    private int NormalFormVariableCount { get; set; } = 2;
    private string NormalFormTruthValuesInput { get; set; } = "0,1,1,0";
    private int QmcVariableCount { get; set; } = 2;
    private string QmcTruthValuesInput { get; set; } = "0,1,1,1";

    private byte AdditionLeftByte => ClampToByte(AdditionLeft);
    private byte AdditionRightByte => ClampToByte(AdditionRight);
    private byte DecimalInputByte => ClampToByte(DecimalInput);
    private byte TwosComplementInputByte => (byte)Math.Clamp(TwosComplementInput, 0, 127);

    private BinaryAdditionSolution AdditionSolution =>
        (BinaryAdditionSolution)additionSolver.Solve(new BinaryAdditionParameters(AdditionLeftByte, AdditionRightByte));

    private DecimalToBinarySolution DecimalToBinarySolution =>
        (DecimalToBinarySolution)decimalToBinarySolver.Solve(new DecimalToBinaryParameters(DecimalInputByte));

    private BinaryToDecimalSolution BinaryToDecimalSolution =>
        (BinaryToDecimalSolution)binaryToDecimalSolver.Solve(new BinaryToDecimalParameters(Convert.ToByte(NormalizedBinaryInput, 2)));

    private TwosComplementSolution TwosComplementSolution =>
        (TwosComplementSolution)twosComplementSolver.Solve(new TwosComplementParameters(TwosComplementInputByte));

    private string NormalizedBinaryInput
    {
        get
        {
            var digits = new string(BinaryInput.Where(ch => ch == '0' || ch == '1').ToArray());
            if (string.IsNullOrWhiteSpace(digits))
            {
                return "0";
            }

            return digits.Length <= 8 ? digits : digits[^8..];
        }
    }

    private static byte ClampToByte(int value) => (byte)Math.Clamp(value, 0, 255);

    private static string ToBinary(int value, int width = 8) => Convert.ToString(value, 2).PadLeft(width, '0');

    private bool TryGetNormalFormSolution(out NormalFormSolution? solution, out string errorMessage)
    {
        try
        {
            var variableCount = Math.Clamp(NormalFormVariableCount, 1, 4);
            var truthValues = ParseTruthValues(NormalFormTruthValuesInput);

            solution = (NormalFormSolution)normalFormSolver.Solve(new NormalFormParameters(variableCount, truthValues));
            errorMessage = string.Empty;
            return true;
        }
        catch (Exception ex)
        {
            solution = null;
            errorMessage = ex.Message;
            return false;
        }
    }

    private bool TryGetQuineMcCluskeySolution(out QuineMcCluskeySolution? solution, out string errorMessage)
    {
        try
        {
            var variableCount = Math.Clamp(QmcVariableCount, 1, 4);
            var truthValues = ParseTruthValues(QmcTruthValuesInput);

            solution = (QuineMcCluskeySolution)quineMcCluskeySolver.Solve(new QuineMcCluskeyParameters(variableCount, truthValues));
            errorMessage = string.Empty;
            return true;
        }
        catch (Exception ex)
        {
            solution = null;
            errorMessage = ex.Message;
            return false;
        }
    }

    private bool TryGetKarnaughMapSolution(out KarnaughMapSolution? solution, out string errorMessage)
    {
        try
        {
            var variableCount = Math.Clamp(QmcVariableCount, 1, 4);
            var truthValues = ParseTruthValues(QmcTruthValuesInput);

            solution = (KarnaughMapSolution)karnaughMapSolver.Solve(new KarnaughMapParameters(variableCount, truthValues));
            errorMessage = string.Empty;
            return true;
        }
        catch (Exception ex)
        {
            solution = null;
            errorMessage = ex.Message;
            return false;
        }
    }

    private static int[] ParseTruthValues(string input) =>
        input
            .Split(new[] { ',', ';', ' ' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(token => int.TryParse(token, out var value)
                ? value
                : throw new InvalidOperationException($"Invalid truth-table value '{token}'."))
            .ToArray();
}
